import { $ } from './editor.js';
let modalResolve = null;
let modalReject = null;

export function showModal(options) {
  const modal = $("universalModal");
  const title = $("modalTitle");
  const message = $("modalMessage");
  const input = $("modalInput");
  const okBtn = $("modalOkBtn");
  const cancelBtn = $("modalCancelBtn");

  // Configure title + message
  title.textContent = options.title || "";
  message.textContent = options.message || "";

  // Configure input
  if (options.input) {
    input.style.display = "block";
    input.value = options.input.defaultValue || "";
    setTimeout(() => { input.focus(); input.select(); }, 0);
  } else {
    input.style.display = "none";
  }

  // Configure buttons
  cancelBtn.style.display = options.okOnly ? "none" : "inline-block";

  // Show modal
  modal.style.display = "block";

  // Return a promise so caller can await result
  return new Promise((resolve, reject) => {
    modalResolve = resolve;
    modalReject = reject;
  });
}

// Close modal
function closeModal() {
  $("universalModal").style.display = "none";
  document.removeEventListener("keydown", handleKeys);
}

// Handle OK
function handleOk() {
  const input = $("modalInput");
  const value = input.style.display === "none" ? null : input.value.trim();
  modalResolve(value);
  closeModal();
}

// Handle Cancel
function handleCancel() {
  modalReject();
  closeModal();
}

// Keyboard shortcuts
function handleKeys(e) {
  if (e.key === "Enter") handleOk();
  if (e.key === "Escape") handleCancel();
}

// Wire up buttons once
$("modalOkBtn").addEventListener("click", handleOk);
$("modalCancelBtn").addEventListener("click", handleCancel);
document.addEventListener("keydown", handleKeys);
